---
extends: default

ignore: |
  .git/
  .terraform/
  .venv/
  build/
  coverage/
  dist/
  node_modules/
  tmp/
  vendor/

rules:
  braces:
    max-spaces-inside: 1
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  line-length:
    max: 120
    level: warning
  octal-values:
    forbid-explicit-octal: true
    forbid-implicit-octal: true
  truthy:
    check-keys: false
